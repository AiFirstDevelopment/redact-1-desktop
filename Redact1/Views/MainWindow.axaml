<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Redact1.Views"
        x:Class="Redact1.Views.MainWindow"
        Title="Redact-1"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <!-- Enrollment View -->
        <views:EnrollmentView x:Name="EnrollmentView"
                              IsVisible="False" />

        <!-- Login View -->
        <views:LoginView x:Name="LoginView"
                         IsVisible="False" />

        <!-- Main Content -->
        <Grid x:Name="MainContent" IsVisible="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryBrush}"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Redact-1"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="UserNameText"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0" />
                        <Button x:Name="LogoutButton"
                                Content="Sign Out"
                                Classes="secondary"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="White" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tab Content -->
            <TabControl x:Name="MainTabControl"
                        Grid.Row="1"
                        Background="Transparent"
                        Padding="0">
                <TabItem Header="Requests">
                    <views:RequestsView x:Name="RequestsView" />
                </TabItem>

                <TabItem Header="Archived">
                    <views:RequestsView x:Name="ArchivedView" />
                </TabItem>

                <TabItem x:Name="UsersTab" Header="Users">
                    <views:UsersView x:Name="UsersView" />
                </TabItem>

                <TabItem Header="Settings">
                    <views:SettingsView x:Name="SettingsView" />
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Request Detail Panel -->
        <Border x:Name="DetailPanel"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0"
                HorizontalAlignment="Right"
                Width="500"
                IsVisible="False">
            <views:RequestDetailView x:Name="RequestDetailView" />
        </Border>

        <!-- New Request Panel -->
        <Border x:Name="NewRequestPanel"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0"
                HorizontalAlignment="Right"
                Width="500"
                IsVisible="False">
            <views:NewRequestView x:Name="NewRequestView" />
        </Border>

        <!-- File Review (full screen overlay) -->
        <Border x:Name="FileReviewPanel"
                Background="{StaticResource SurfaceBrush}"
                IsVisible="False">
            <views:FileReviewView x:Name="FileReviewView" />
        </Border>
    </Grid>
</Window>
