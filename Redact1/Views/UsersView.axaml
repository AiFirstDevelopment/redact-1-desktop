<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Redact1.Views.UsersView"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Users"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <Button Grid.Column="1"
                    Content="+ Add User"
                    Classes="primary"
                    Command="{Binding StartCreateUserCommand}" />
        </Grid>

        <!-- Users List -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Users}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="card" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Text="{Binding Email}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,4,0,0" />
                                    <Border Margin="0,8,0,0"
                                            Padding="8,4"
                                            CornerRadius="4"
                                            Background="{StaticResource BackgroundBrush}"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Role}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Edit"
                                            Classes="secondary"
                                            Command="{Binding $parent[UserControl].DataContext.StartEditUserCommand}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,8,0" />
                                    <Button Content="Delete"
                                            Classes="danger"
                                            Command="{Binding $parent[UserControl].DataContext.RequestDeleteUserCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Edit Dialog Overlay -->
        <Border Grid.RowSpan="2"
                Background="#80000000"
                IsVisible="{Binding IsEditing}">
            <Border Classes="card"
                    Width="400"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="User Details" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20" />

                    <TextBlock Text="Name" FontWeight="Medium" Margin="0,0,0,8" />
                    <TextBox Text="{Binding EditName}" Classes="modern" Margin="0,0,0,16" />

                    <TextBlock Text="Email" FontWeight="Medium" Margin="0,0,0,8" />
                    <TextBox Text="{Binding EditEmail}" Classes="modern" Margin="0,0,0,16" />

                    <TextBlock Text="Role" FontWeight="Medium" Margin="0,0,0,8" />
                    <ComboBox SelectedIndex="0" Margin="0,0,0,16">
                        <ComboBoxItem Content="Clerk" Tag="clerk" />
                        <ComboBoxItem Content="Supervisor" Tag="supervisor" />
                    </ComboBox>

                    <TextBlock Text="Password (leave blank to keep current)" FontWeight="Medium" Margin="0,0,0,8" />
                    <TextBox x:Name="EditPasswordBox" PasswordChar="*" Classes="modern" Margin="0,0,0,24" />

                    <!-- Error Message -->
                    <Border Background="#F5E5E5"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,16"
                            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#A06A69" TextWrapping="Wrap" />
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Cancel"
                                Classes="secondary"
                                Command="{Binding CancelEditCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="1"
                                Content="Save"
                                Classes="primary"
                                Command="{Binding SaveUserCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Delete Confirmation Modal -->
        <Border Grid.RowSpan="2"
                Background="#80000000"
                IsVisible="{Binding IsConfirmingDelete}">
            <Border Classes="card"
                    Width="400"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Confirm Delete"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ErrorBrush}"
                               Margin="0,0,0,16" />

                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,24">
                        <Run Text="Are you sure you want to delete " />
                        <Run Text="{Binding UserToDelete.Name}" FontWeight="SemiBold" />
                        <Run Text="? This action cannot be undone." />
                    </TextBlock>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Cancel"
                                Classes="secondary"
                                Command="{Binding CancelDeleteCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="1"
                                Content="Delete"
                                Classes="danger"
                                Command="{Binding ConfirmDeleteCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Loading -->
        <Border Grid.RowSpan="2"
                Background="#80FFFFFF"
                IsVisible="{Binding IsLoading}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
