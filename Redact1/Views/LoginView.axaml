<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Redact1.Views.LoginView"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Border Classes="card"
                Width="420"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="32">
            <StackPanel Spacing="4">
                <!-- Logo/Title -->
                <TextBlock Text="Redact-1"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <TextBlock Text="Police Records Redaction System"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32" />

                <!-- Error Message -->
                <Border Background="#F5E5E5"
                        CornerRadius="10"
                        Padding="14"
                        Margin="0,0,0,16"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#A06A69"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Email -->
                <TextBlock Text="Email"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBox x:Name="EmailTextBox"
                         Text="{Binding Email}"
                         Classes="modern"
                         Margin="0,0,0,20" />

                <!-- Password -->
                <TextBlock Text="Password"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBox x:Name="PasswordBox"
                         Text="{Binding Password}"
                         PasswordChar="*"
                         Classes="modern"
                         Margin="0,0,0,28" />

                <!-- Login Button -->
                <Button x:Name="LoginButton"
                        Content="Sign In"
                        Classes="primary"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding !IsLoading}"
                        Margin="0,0,0,12" />

                <!-- Demo Credentials -->
                <Button Content="Use Demo Credentials"
                        Classes="ghost"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        Command="{Binding UseDemoCredentialsCommand}" />

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True"
                             Height="3"
                             Margin="0,20,0,0"
                             Foreground="{StaticResource PrimaryBrush}"
                             IsVisible="{Binding IsLoading}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
