<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Redact1.ViewModels"
             x:Class="Redact1.Views.EnrollmentView"
             x:DataType="vm:EnrollmentViewModel"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Border Classes="card"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="440"
                Padding="40">
            <StackPanel Spacing="24">
                <!-- Header -->
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="Redact-1"
                               FontSize="38"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Police Records Redaction System"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Connect to Department Section -->
                <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <TextBlock Text="Connect to Your Department"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter your department code to get started"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Department Code Input -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Department Code"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBox x:Name="DepartmentCodeBox"
                             Text="{Binding DepartmentCode}"
                             Watermark="e.g. SPRINGFIELD-PD"
                             Classes="modern"/>
                    <TextBlock Text="This code was provided by your department's IT administrator"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <!-- Error Message -->
                <Border Background="#FEE2E2"
                        CornerRadius="10"
                        Padding="14"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Connect Button -->
                <Button x:Name="ConnectButton"
                        Command="{Binding ConnectCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Classes="primary"
                        IsEnabled="{Binding !IsLoading}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Connect to Department"
                                   IsVisible="{Binding !IsLoading}"/>
                        <TextBlock Text="Connecting..."
                                   IsVisible="{Binding IsLoading}"/>
                    </StackPanel>
                </Button>

                <!-- Use Demo Button -->
                <Button Command="{Binding UseDemoCommand}"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        Classes="ghost">
                    <TextBlock Text="Use Demo Department"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
